Import('env')

libcosmos = env['libs']['libcosmos']

tests = (
	"bitmask",
	"dirs",
	"exceptions",
	"pipe",
	"subproc",
	"thread_primitives",
)

for test in tests:

	test_bin = env.Program(
		"test_{}".format(test),
		["{}.cxx".format(test), libcosmos]
	)

	env.Alias("cosmos_tests", test_bin)

env.Alias("tests", "cosmos_tests")
