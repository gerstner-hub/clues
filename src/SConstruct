Import('env')

lib_srcs = [
	"Arch.cxx",
	"TracedProc.cxx",
	"TracedThread.cxx",
	"SubProc.cxx",
	"errors/ApiError.cxx",
	"errors/CluesError.cxx",
	"types.cxx",
	"WaitRes.cxx",
	"Signal.cxx",
	"SystemCall.cxx",
	"SystemCallDB.cxx",
	"SystemCallParameter.cxx",
	"Parameters.cxx",
	"RegisterSet.cxx",
	"Pipe.cxx",
	"Process.cxx",
	"fs/Directory.cxx",
	"fs/FileSystem.cxx",
	"threading/Mutex.cxx",
	"threading/Condition.cxx",
	"time/Clock.cxx",
	"Init.cxx",
	"Scheduler.cxx",
	"utils.cxx"
]

tracer_srcs = [
	"TermTracer.cxx",
]

libenv = env.Clone()
libenv.Append( CPPPATH = ["."] )

tracelib = libenv.SharedLibrary(
	"clues",
	[ "lib/" + src for src in lib_srcs ]
)

clues = env.Program(
	"clues",
	[ "termtracer/" + src for src in tracer_srcs ] + [tracelib]
)

env['libs']['clues'] = tracelib

# required to link against us regarding threading functionality
env.Append( LINKFLAGS = "-pthread" )
