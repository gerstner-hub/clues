Import('env')

lib_srcs = [
	"Arch.cxx",
	"TracedProc.cxx",
	"TracedThread.cxx",
	"SubProc.cxx",
	"errors/ApiError.cxx",
	"errors/CluesError.cxx",
	"types.cxx",
	"WaitRes.cxx",
	"Signal.cxx",
	"SystemCall.cxx",
	"SystemCallDB.cxx",
	"SystemCallParameter.cxx",
	"Parameters.cxx",
	"RegisterSet.cxx"
]

tracer_srcs = [
	"TermTracer.cxx",
]

tracelib = env.SharedLibrary(
	"clues",
	[ "lib/" + src for src in lib_srcs ]
)

clues = env.Program(
	"clues",
	[ "termtracer/" + src for src in tracer_srcs ] + [tracelib]
)

env['libs']['clues'] = tracelib
